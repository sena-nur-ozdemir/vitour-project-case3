@model Case3Vitour.Dtos.ReviewDtos.CreateReviewDto

@{
    ViewData["Title"] = "Yeni Yorum Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "yorumlar";
    ViewData["Breadcrumb"] = "Yorumlar / Yeni";
    var tours = ViewBag.Tours as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<style>
    .create-grid { display: grid; grid-template-columns: 1fr 320px; gap: 24px; align-items: start; }

    .v-card { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 24px; overflow: hidden; }
    .v-card-header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px; background: #f8fafc; }
    .v-card-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
    .v-card-title { font-size: 15px; font-weight: 700; color: var(--t1); }
    .v-card-sub { font-size: 12px; color: var(--t3); margin-top: 2px; }
    .form-body { padding: 24px; display: flex; flex-direction: column; gap: 20px; }

    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--t2); display: flex; align-items: center; gap: 6px; }
    .req { color: #ef4444; font-size: 15px; line-height: 1; }

    .form-control { width: 100%; height: 42px; padding: 0 14px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); background: #fff; color: var(--t1); font-family: inherit; font-size: 14px; transition: all .2s; outline: none; }
    .form-control:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
    textarea.form-control { min-height: 120px; padding: 12px 14px; resize: vertical; line-height: 1.6; }
    select.form-control { appearance: none; cursor: pointer; }

    .field-validation-error { font-size: 12px; color: #ef4444; margin-top: 4px; display: block; }

    /* Puanlama Satırları */
    .rating-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: #f8fafc; border: 1px solid var(--border); border-radius: 8px;}
    .rating-label { font-size: 13px; font-weight: 600; color: var(--t2); }
    .star-picker { display: flex; flex-direction: row-reverse; gap: 4px; }
    .star-picker input { display: none; }
    .star-picker label { font-size: 24px; color: #e2e8f0; cursor: pointer; transition: all .2s; line-height: 1; }
    .star-picker label:hover, .star-picker label:hover ~ label, .star-picker input:checked ~ label { color: #f59e0b; }

    /* Butonlar */
    .form-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: flex-end; gap: 12px; background: #f8fafc; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 0 20px; height: 40px; border-radius: 6px; font-size: 13.5px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: all .2s; }
    .btn-primary { background: #0d9488; color: #fff; }
    .btn-primary:hover { background: #0f766e; }
    .btn-ghost { border: 1.5px solid var(--border); background: transparent; color: var(--t2); }
    .btn-ghost:hover { background: var(--bg-hover); color: var(--t1); }

    /* Durum Switch */
    .toggle-row { display: flex; align-items: center; justify-content: space-between; cursor: pointer; padding: 12px 16px; background: #fff; border: 1.5px solid var(--border); border-radius: 8px;}
    .toggle-input { appearance: none; width: 44px; height: 24px; border-radius: 99px; background: #cbd5e1; position: relative; cursor: pointer; transition: .2s; flex-shrink:0;}
    .toggle-input::after { content: ''; position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; border-radius: 50%; background: #fff; transition: .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
    .toggle-input:checked { background: #10b981; }
    .toggle-input:checked::after { transform: translateX(20px); }

    /* Önizleme Kartı */
    .review-card { padding: 18px; background: #fff; border: 1.5px dashed #cbd5e1; border-radius: var(--radius-sm); display: flex; flex-direction: column; gap: 12px; }
    .rc-header { display: flex; align-items: center; gap: 12px; }
    .rc-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg,#dbeafe,#bfdbfe); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 800; color: #2563eb; text-transform: uppercase; }
    .rc-name { font-size: 14px; font-weight: 700; color: var(--t1); }
    .rc-date { font-size: 11.5px; color: var(--t3); margin-top: 1px; }
    .rc-stars i { font-size: 14px; color: #e2e8f0; }
    .rc-stars i.lit { color: #f59e0b; }
    .rc-comment { font-size: 13px; color: var(--t2); line-height: 1.6; font-style: italic; }
    .rc-tour-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 11.5px; color: #0d9488; font-weight: 600; background: rgba(13,148,136,.1); padding: 4px 10px; border-radius: 20px; width: fit-content; }
    .rc-status { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; font-weight: 600; padding: 3px 9px; border-radius: 20px; width: fit-content; }
    .rc-status.active { background: rgba(16,185,129,.1); color: #10b981; }
    .rc-status.inactive { background: rgba(148,163,184,.1); color: #64748b; }

    @@media (max-width:900px) { .create-grid { grid-template-columns: 1fr; } }
</style>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
        <h1 style="font-size:22px;font-weight:800;color:var(--t1);">Yeni Yorum Ekle</h1>
        <p style="font-size:13px;color:var(--t3);margin-top:3px;">Tura ait detaylı değerlendirme girişi.</p>
    </div>
    <a asp-action="ReviewList" class="btn btn-ghost"><i class="fa-solid fa-arrow-left"></i> Listeye Dön</a>
</div>

<div class="create-grid">
    <form method="post" asp-action="CreateReview" style="display:flex;flex-direction:column;gap:20px;">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:#fef2f2; border:1px solid #fecaca; padding:15px; border-radius:8px; color:#dc2626; font-size:13px;">
                <div style="font-weight:700; margin-bottom:5px;"><i class="fa-solid fa-circle-exclamation"></i> Lütfen hataları düzeltin:</div>
                <div asp-validation-summary="All"></div>
            </div>
        }

        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(13,148,136,.1);color:#0d9488;"><i class="fa-solid fa-user-pen"></i></div>
                <div>
                    <div class="v-card-title">Müşteri ve Tur Bilgileri</div>
                </div>
            </div>
            <div class="form-body">
                <div class="form-group">
                    <label asp-for="TourId" class="form-label">Hangi Tur İçin? <span class="req">*</span></label>
                    <select asp-for="TourId" class="form-control" asp-items="tours" id="inpTour">
                        <option value="">— Tur Seçiniz —</option>
                    </select>
                </div>
                <div class="form-group">
                    <label asp-for="NameSurname" class="form-label">Ad Soyad <span class="req">*</span></label>
                    <input asp-for="NameSurname" class="form-control" id="inpName" placeholder="Müşteri Adı" />
                </div>
                <div class="form-group">
                    <label asp-for="Comment" class="form-label">Yorum Metni <span class="req">*</span></label>
                    <textarea asp-for="Comment" class="form-control" id="inpComment" placeholder="Tur hakkındaki görüşler..."></textarea>
                </div>
            </div>
        </div>

        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(245,158,11,.1);color:#f59e0b;"><i class="fa-solid fa-star"></i></div>
                <div>
                    <div class="v-card-title">Hizmet Değerlendirmesi</div>
                    <div class="v-card-sub">Ortalama puan otomatik hesaplanır</div>
                </div>
            </div>
            <div class="form-body" style="gap:12px;">
                <div class="rating-row">
                    <span class="rating-label"><i class="fa-solid fa-person-walking-luggage" style="color:#64748b; margin-right:6px;"></i> Rehberlik</span>
                    <div class="star-picker">
                        <input type="radio" asp-for="GuideScore" value="5" id="g5" /><label for="g5">★</label>
                        <input type="radio" asp-for="GuideScore" value="4" id="g4" /><label for="g4">★</label>
                        <input type="radio" asp-for="GuideScore" value="3" id="g3" /><label for="g3">★</label>
                        <input type="radio" asp-for="GuideScore" value="2" id="g2" /><label for="g2">★</label>
                        <input type="radio" asp-for="GuideScore" value="1" id="g1" checked /><label for="g1">★</label>
                    </div>
                </div>
                <div class="rating-row">
                    <span class="rating-label"><i class="fa-solid fa-hotel" style="color:#64748b; margin-right:6px;"></i> Konaklama</span>
                    <div class="star-picker">
                        <input type="radio" asp-for="AccommodationScore" value="5" id="a5" /><label for="a5">★</label>
                        <input type="radio" asp-for="AccommodationScore" value="4" id="a4" /><label for="a4">★</label>
                        <input type="radio" asp-for="AccommodationScore" value="3" id="a3" /><label for="a3">★</label>
                        <input type="radio" asp-for="AccommodationScore" value="2" id="a2" /><label for="a2">★</label>
                        <input type="radio" asp-for="AccommodationScore" value="1" id="a1" checked /><label for="a1">★</label>
                    </div>
                </div>
                <div class="rating-row">
                    <span class="rating-label"><i class="fa-solid fa-bus" style="color:#64748b; margin-right:6px;"></i> Ulaşım</span>
                    <div class="star-picker">
                        <input type="radio" asp-for="TransportationScore" value="5" id="t5" /><label for="t5">★</label>
                        <input type="radio" asp-for="TransportationScore" value="4" id="t4" /><label for="t4">★</label>
                        <input type="radio" asp-for="TransportationScore" value="3" id="t3" /><label for="t3">★</label>
                        <input type="radio" asp-for="TransportationScore" value="2" id="t2" /><label for="t2">★</label>
                        <input type="radio" asp-for="TransportationScore" value="1" id="t1" checked /><label for="t1">★</label>
                    </div>
                </div>
                <div class="rating-row">
                    <span class="rating-label"><i class="fa-solid fa-sack-dollar" style="color:#64748b; margin-right:6px;"></i> Fiyat/Performans</span>
                    <div class="star-picker">
                        <input type="radio" asp-for="ValueForMoneyScore" value="5" id="v5" /><label for="v5">★</label>
                        <input type="radio" asp-for="ValueForMoneyScore" value="4" id="v4" /><label for="v4">★</label>
                        <input type="radio" asp-for="ValueForMoneyScore" value="3" id="v3" /><label for="v3">★</label>
                        <input type="radio" asp-for="ValueForMoneyScore" value="2" id="v2" /><label for="v2">★</label>
                        <input type="radio" asp-for="ValueForMoneyScore" value="1" id="v1" checked /><label for="v1">★</label>
                    </div>
                </div>

                <div style="text-align:right; font-size:13px; font-weight:700; color:#0d9488; margin-top:5px;">
                    Ortalama: <span id="avgDisplay" style="font-size:18px;">1.0</span> / 5
                </div>
            </div>
        </div>

        <div class="v-card">
            <div class="v-card-body" style="padding:16px 24px;">
                <label class="toggle-row" for="StatusChk">
                    <div>
                        <div style="font-size:14px; font-weight:700; color:var(--t1);">Yorumu Yayına Al</div>
                        <div style="font-size:12px; color:var(--t3); margin-top:2px;">Aktif yorumlar ziyaretçilere gösterilir.</div>
                    </div>
                    <input asp-for="Status" type="checkbox" class="toggle-input" id="StatusChk" />
                </label>
            </div>
            <div class="form-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Yorumu Kaydet
                </button>
            </div>
        </div>
    </form>

    <div class="side-panel">
        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(168,85,247,.1);color:#a855f7;"><i class="fa-solid fa-eye"></i></div>
                <div>
                    <div class="v-card-title">Canlı Önizleme</div>
                </div>
            </div>
            <div class="v-card-body" style="background:#f8fafc;">
                <div class="review-card">
                    <div class="rc-header">
                        <div class="rc-avatar" id="prevAvatar">?</div>
                        <div>
                            <div class="rc-name" id="prevName"><span style="color:var(--t3);font-weight:400;">Ad girilmedi...</span></div>
                            <div class="rc-date">@DateTime.Now.ToString("dd MMM yyyy")</div>
                        </div>
                    </div>
                    <div class="rc-stars" id="prevStars">
                        <i class="fa-solid fa-star lit"></i>
                        <i class="fa-regular fa-star"></i>
                        <i class="fa-regular fa-star"></i>
                        <i class="fa-regular fa-star"></i>
                        <i class="fa-regular fa-star"></i>
                    </div>
                    <div class="rc-comment" id="prevComment"><span style="color:var(--t3);font-style:normal;">Yorum metni girilmedi...</span></div>
                    <div id="prevTourWrap" style="display:none;">
                        <span class="rc-tour-tag"><i class="fa-solid fa-map-location-dot"></i> <span id="prevTourName"></span></span>
                    </div>
                    <div>
                        <span class="rc-status inactive" id="prevStatus"><span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span> Pasif</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var inpName = document.getElementById('inpName');
        var inpComment = document.getElementById('inpComment');
        var inpTour = document.getElementById('inpTour');
        var statusChk = document.getElementById('StatusChk');

        function getRadioVal(name) {
            var el = document.querySelector('input[name="'+name+'"]:checked');
            return el ? parseInt(el.value) : 1;
        }

        function refreshPreview() {
            var name = inpName.value.trim();
            var comment = inpComment.value.trim();
            var active = statusChk.checked;

            // 4 Kriterin Ortalamasını Hesapla
            var g = getRadioVal("GuideScore");
            var a = getRadioVal("AccommodationScore");
            var t = getRadioVal("TransportationScore");
            var v = getRadioVal("ValueForMoneyScore");
            var avg = (g + a + t + v) / 4.0;

            document.getElementById('avgDisplay').textContent = avg.toFixed(1);

            // Avatar & İsim
            var avatarEl = document.getElementById('prevAvatar');
            var nameEl = document.getElementById('prevName');
            if (name) {
                avatarEl.textContent = name.substring(0,2).toUpperCase();
                avatarEl.style.background = 'linear-gradient(135deg,#0d9488,#2dd4bf)';
                avatarEl.style.color = '#fff';
                nameEl.innerHTML = name;
            } else {
                avatarEl.textContent = '?';
                avatarEl.style.background = 'linear-gradient(135deg,#dbeafe,#bfdbfe)';
                avatarEl.style.color = '#2563eb';
                nameEl.innerHTML = '<span style="color:var(--t3);font-weight:400;">Ad girilmedi...</span>';
            }

            // Yıldızlar (Ortalamaya Göre)
            var stars = document.getElementById('prevStars').querySelectorAll('i');
            var roundedAvg = Math.round(avg);
            stars.forEach(function (s, i) {
                s.className = i < roundedAvg ? 'fa-solid fa-star lit' : 'fa-regular fa-star';
            });

            // Yorum
            document.getElementById('prevComment').innerHTML = comment ? '"' + comment + '"' : '<span style="color:var(--t3);font-style:normal;">Yorum metni girilmedi...</span>';

            // Tur Tag
            var tourOpt = inpTour.options[inpTour.selectedIndex];
            if (tourOpt && tourOpt.value) {
                document.getElementById('prevTourWrap').style.display = 'block';
                document.getElementById('prevTourName').textContent = tourOpt.text;
            } else {
                document.getElementById('prevTourWrap').style.display = 'none';
            }

            // Durum
            var statusEl = document.getElementById('prevStatus');
            statusEl.className = 'rc-status ' + (active ? 'active' : 'inactive');
            statusEl.innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;"></span> ' + (active ? 'Yayında' : 'Pasif');
        }

        // Dinleyiciler
        inpName.addEventListener('input', refreshPreview);
        inpComment.addEventListener('input', refreshPreview);
        inpTour.addEventListener('change', refreshPreview);
        statusChk.addEventListener('change', refreshPreview);

        document.querySelectorAll('input[type="radio"]').forEach(r => r.addEventListener('change', refreshPreview));

        refreshPreview();
    </script>
}