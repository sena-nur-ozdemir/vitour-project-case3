@model Case3Vitour.Dtos.TourDtos.TourDetailDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="tr-TR" lang="tr">

@await Component.InvokeAsync("_TourHeadComponentPartial")


<body class="body header-fixed">

    <div class="preload preload-container">
        <svg class="pl" width="240" height="240" viewBox="0 0 240 240">
            <circle class="pl__ring pl__ring--a" cx="120" cy="120" r="105" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 660" stroke-dashoffset="-330" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--b" cx="120" cy="120" r="35" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 220" stroke-dashoffset="-110" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--c" cx="85" cy="120" r="70" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 440" stroke-linecap="round"></circle>
            <circle class="pl__ring pl__ring--d" cx="155" cy="120" r="70" fill="none" stroke="#000" stroke-width="20" stroke-dasharray="0 440" stroke-linecap="round"></circle>
        </svg>
    </div>

    <div id="wrapper">
        <div id="pagee" class="clearfix">

            @await Component.InvokeAsync("_TourHeaderComponentPartial")

            <main id="main">
                <section>
                    <div class="tf-container full">
                        <div class="row">
                            <div class="col-md-12">
                                <img src="@Model.CoverImageUrl" style="height:400px; width:100%; object-fit:cover" alt="Tur Görseli">
                            </div>
                        </div>
                    </div>
                </section>

                <section class="tour-single">
                    <div class="tf-container">
                        <div class="row">
                            <div class="col-lg-12">
                                <ul class="nav justify-content-between tab-tour-single" id="pills-tab" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="pills-information-tab" data-bs-toggle="pill" data-bs-target="#pills-information" type="button" role="tab" aria-controls="pills-information" aria-selected="true">
                                            <i class="icon-Vector-51"></i> Açıklama
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="pills-tour-planing-tab" data-bs-toggle="pill" data-bs-target="#pills-tour-planing" type="button" role="tab" aria-controls="pills-tour-planing" aria-selected="false">
                                            <i class="icon-destination-2-1"></i> Tur Planı
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="pills-location-share-tab" data-bs-toggle="pill" data-bs-target="#pills-location-share" type="button" role="tab" aria-controls="pills-location-share" aria-selected="false">
                                            <i class="icon-map-1"></i> Rota Konumu
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="pills-reviews-tab" data-bs-toggle="pill" data-bs-target="#pills-reviews" type="button" role="tab" aria-controls="pills-reviews" aria-selected="false">
                                            <i class="icon-favourite-1"></i> Yorumlar
                                        </button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="pills-shot-gallery-tab" data-bs-toggle="pill" data-bs-target="#pills-shot-gallery" type="button" role="tab" aria-controls="pills-shot-gallery" aria-selected="false">
                                            <i class="icon-image-gallery-1"></i> Galeri
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="row pd-main">
                            <div class="col-lg-12">
                                <div class="tab-content" id="pills-tabContent">
                                    @await Component.InvokeAsync("_TourDetailsInformationComponentPartial", new { id = Model.TourId })
                                    @await Component.InvokeAsync("_TourDetailsPlanComponentPartial", new { id = Model.TourId })
                                    @await Component.InvokeAsync("_TourDetailsLocationComponentPartial", new { id = Model.TourId })
                                    @await Component.InvokeAsync("_TourDetailsReviewsComponentPartial", new { id = Model.TourId })
                                    @await Component.InvokeAsync("_TourDetailsGalleryComponentPartial", new { id = Model.TourId })
                                </div>
                            </div>
                        </div>

                    </div>
                </section>
            </main>

            @await Component.InvokeAsync("_TourFooterComponentPartial")

        </div>
    </div>

    @await Component.InvokeAsync("_TourScriptsComponentPartial")

    <script src="/vitour/app/js/map.min.js"></script>
    <script src="/vitour/app/js/map.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // URL'de 'submittedReview' işaretçisi var mı kontrol et
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('submittedReview')) {

                // Temanın Yorumlar sekmesi butonunu bul
                var reviewTab = document.getElementById('pills-reviews-tab');
                if (reviewTab) {
                    // Butona otomatik tıkla (Sekme şak diye açılacak)
                    reviewTab.click();

                    // Ekranı yumuşak bir şekilde yorumlar alanına kaydır
                    reviewTab.scrollIntoView({ behavior: 'smooth' });
                }
            }
        });
    </script>

</body>
</html>