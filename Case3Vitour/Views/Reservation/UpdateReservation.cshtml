@model Case3Vitour.Dtos.ReservationDtos.UpdateReservationDto

@{
    ViewData["Title"] = "Rezervasyon Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "rezervasyonlar";
    ViewData["Breadcrumb"] = "Rezervasyonlar / Düzenle";
    var tours = ViewBag.Tours as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 1fr 380px; 
        gap: 24px;
        align-items: start;
    }

    .v-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        margin-bottom: 24px;
        overflow: hidden;
    }

    .v-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #f8fafc;
    }

    .v-card-title-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .v-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .v-card-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--t1);
    }

    .v-card-sub {
        font-size: 12px;
        color: var(--t3);
        margin-top: 2px;
    }

    .form-body {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--t2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .req {
        color: #ef4444;
        font-size: 15px;
        line-height: 1;
    }

    .form-control {
        width: 100%;
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: #fff;
        color: var(--t1);
        font-family: inherit;
        font-size: 14px;
        transition: all .2s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
        }

        .form-control[readonly] {
            background: #f1f5f9;
            cursor: not-allowed;
            color: var(--t3);
            font-family: monospace;
            font-weight: 700;
        }

    .field-validation-error {
        font-size: 12px;
        color: #ef4444;
        margin-top: 4px;
        display: block;
    }

    .form-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        background: #f8fafc;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 20px;
        height: 40px;
        border-radius: 6px;
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: all .2s;
    }

    .btn-primary {
        background: #0d9488;
        color: #fff;
    }

        .btn-primary:hover {
            background: #0f766e;
            transform: translateY(-1px);
        }

    .btn-ghost {
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--t2);
    }

        .btn-ghost:hover {
            background: var(--bg-hover);
            color: var(--t1);
        }

    .info-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 0;
    }

    .info-item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

    .info-icon {
        width: 24px;
        height: 24px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        flex-shrink: 0;
    }

    .info-text {
        font-size: 12.5px;
        color: var(--t2);
        line-height: 1.5;
    }

        .info-text strong {
            color: var(--t1);
        }

    @@media (max-width:900px) {
        .page-grid

    {
        grid-template-columns: 1fr;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    }
</style>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
    <div>
        <h1 style="font-size:22px;font-weight:800;color:var(--t1);">Rezervasyon Düzenle</h1>
        <p style="font-size:13px;color:var(--t3);margin-top:3px;">Sistemde kayıtlı olan rezervasyon bilgilerini güncelleyin.</p>
    </div>
    <a asp-action="ReservationList" class="btn btn-ghost"><i class="fa-solid fa-arrow-left"></i> İptal ve Geri Dön</a>
</div>

<div class="page-grid">
    <form method="post" asp-action="UpdateReservation" style="display:flex;flex-direction:column;gap:24px;">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReservationId" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:#fef2f2; border:1px solid #fecaca; padding:15px; border-radius:8px; color:#dc2626; font-size:13px;">
                <div style="font-weight:700; margin-bottom:5px;"><i class="fa-solid fa-circle-exclamation"></i> Lütfen hataları düzeltin:</div>
                <div asp-validation-summary="All"></div>
            </div>
        }

        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-title-wrap">
                    <div class="v-card-icon" style="background:rgba(13,148,136,.1);color:#0d9488;"><i class="fa-solid fa-user-check"></i></div>
                    <div>
                        <div class="v-card-title">Müşteri ve Tur Bilgileri</div>
                        <div class="v-card-sub">Temel iletişim ve rota bilgisi</div>
                    </div>
                </div>
                <div style="font-family:monospace; font-size:13px; font-weight:700; color:#7c3aed; background:rgba(124,58,237,.1); padding:4px 10px; border-radius:6px;">
                    #@Model.ReservationCode
                </div>
            </div>

            <div class="form-body">
                <input type="hidden" asp-for="ReservationCode" />

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="NameSurname" class="form-label">Ad Soyad <span class="req">*</span></label>
                        <input asp-for="NameSurname" class="form-control" />
                        <span asp-validation-for="NameSurname" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">E-Posta <span class="req">*</span></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="TourId" class="form-label">Tur Rotası <span class="req">*</span></label>
                    <select asp-for="TourId" class="form-control" asp-items="tours" style="cursor:pointer;"></select>
                    <span asp-validation-for="TourId" class="field-validation-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="PersonCount" class="form-label">Kişi Sayısı <span class="req">*</span></label>
                        <input asp-for="PersonCount" class="form-control" type="number" min="1" />
                        <span asp-validation-for="PersonCount" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="TotalPrice" class="form-label">Toplam Tutar (₺) <span class="req">*</span></label>
                        <input asp-for="TotalPrice" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="TotalPrice" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="ReservationDate" class="form-label">Rezervasyon Tarihi <span class="req">*</span></label>
                    <input asp-for="ReservationDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="ReservationDate" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                </button>
            </div>
        </div>
    </form>

    <div class="v-card">
        <div class="v-card-header">
            <div class="v-card-title-wrap">
                <div class="v-card-icon" style="background:rgba(245,158,11,.1);color:#f59e0b;"><i class="fa-solid fa-circle-info"></i></div>
                <div><div class="v-card-title">Düzenleme Notları</div></div>
            </div>
        </div>
        <div class="v-card-body">
            <ul class="info-list">
                <li class="info-item">
                    <div class="info-icon" style="background:rgba(2,132,199,.1);color:#0284c7;"><i class="fa-solid fa-hashtag"></i></div>
                    <div class="info-text"><strong>Rezervasyon Kodu</strong> sistem tarafından benzersiz olarak üretilmiştir ve değiştirilemez.</div>
                </li>
                <li class="info-item">
                    <div class="info-icon" style="background:rgba(34,197,94,.1);color:#16a34a;"><i class="fa-solid fa-money-bill-wave"></i></div>
                    <div class="info-text">Kişi sayısını değiştirdiğinizde <strong>Toplam Tutar</strong> otomatik güncellenmez. Tutarı manuel olarak hesaplayıp girmelisiniz.</div>
                </li>
                <li class="info-item">
                    <div class="info-icon" style="background:rgba(168,85,247,.1);color:#a855f7;"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="info-text">Tarih alanındaki saat dilimi, müşterinin rezervasyonu oluşturduğu anı temsil eder. Sadece gerekli durumlarda değiştirin.</div>
                </li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}