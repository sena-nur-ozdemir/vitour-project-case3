@model Case3Vitour.Dtos.CategoryDtos.CreateCategoryDto
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "kategoriler";
    ViewData["Breadcrumb"] = "Kategoriler / Yeni";
}

<style>
    /* ── İki Sütunlu Grid Yapısı ── */
    .create-wrapper {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 25px;
        align-items: start;
    }

    /* ── Kart Tasarımı ── */
    .form-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
        overflow: hidden;
    }

    .form-card-header {
        padding: 20px 25px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fafafa;
    }

    .header-icon {
        width: 38px;
        height: 38px;
        background: var(--primary-soft);
        color: var(--primary);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    /* ── Form Elemanları ── */
    .form-container {
        padding: 25px;
    }

    .custom-label {
        display: block;
        font-weight: 700;
        font-size: 0.85rem;
        color: var(--text-main);
        margin-bottom: 8px;
    }

    .custom-input {
        width: 100%;
        padding: 12px 15px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        outline: none;
        transition: 0.2s;
        background: var(--bg-canvas);
    }

        .custom-input:focus {
            border-color: var(--primary);
            background: #fff;
            box-shadow: 0 0 0 4px var(--primary-soft);
        }

    /* ── Toggle Switch (Durum Butonu) ── */
    .status-switch {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 15px;
        background: var(--bg-canvas);
        border: 1px solid var(--border);
        border-radius: 12px;
        cursor: pointer;
        transition: 0.2s;
    }

        .status-switch:hover {
            border-color: var(--primary);
        }

    .switch {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 22px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background-color: #cbd5e1;
        transition: .3s;
        border-radius: 34px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: var(--primary);
    }

        input:checked + .slider:before {
            transform: translateX(22px);
        }

    /* ── Sağ Panel Bilgi Kutuları ── */
    .info-box {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px;
        margin-bottom: 20px;
    }

    .info-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 12px;
        color: var(--text-main);
    }

    .tip-item {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 10px;
        display: flex;
        gap: 8px;
        line-height: 1.4;
    }

    @@media (max-width: 1024px) {
        .create-wrapper {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-head" style="margin-bottom: 25px;">
    <div>
        <h2 style="font-weight: 800;">Yeni Kategori Oluştur</h2>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Turları gruplandırmak için yeni bir kategori tanımı yapın.</p>
    </div>
</div>

<div class="create-wrapper">
    <div class="form-card">
        <div class="form-card-header">
            <div class="header-icon"><i class="fa-solid fa-folder-plus"></i></div>
            <div>
                <div style="font-weight: 700; font-size: 0.95rem;">Genel Bilgiler</div>
                <div style="font-size: 0.75rem; color: var(--text-muted);">Zorunlu alanları doldurmayı unutmayın.</div>
            </div>
        </div>

        <form method="post" asp-action="CreateCategory" asp-controller="Category">
            @Html.AntiForgeryToken()
            <div class="form-container">

                <div style="margin-bottom: 25px;">
                    <label class="custom-label" asp-for="CategoryName">Kategori Adı</label>
                    <input type="text" asp-for="CategoryName" class="custom-input" placeholder="Örn: Doğa ve Macera Turları" />
                    <span asp-validation-for="CategoryName" class="text-danger" style="font-size: 0.75rem; font-weight: 600;"></span>
                </div>

                <div style="margin-bottom: 25px;">
                    <label class="custom-label">Yayın Durumu</label>
                    <label class="status-switch" for="statusToggle">
                        <div style="display:flex; flex-direction:column; gap:2px;">
                            <span style="font-weight:700; font-size:0.85rem;">Aktif Olarak İşaretle</span>
                            <span style="font-size:0.75rem; color:var(--text-muted);">Kategori sitede hemen görünür olur.</span>
                        </div>
                        <div class="switch">
                            <input type="checkbox" asp-for="CategoryStatus" id="statusToggle">
                            <span class="slider"></span>
                        </div>
                    </label>
                </div>

                <div style="display:flex; gap:10px; padding-top:20px; border-top: 1px solid var(--border);">
                    <button type="submit"
                            style="background-color: #0f8b8d;
               color: #ffffff;
               padding: 12px 25px;
               border-radius: 10px;
               border: none;
               font-weight: 700;
               cursor: pointer;
               display: inline-flex;
               align-items: center;
               gap: 8px;">
                        <i class="fa-solid fa-check"></i> Kaydet
                    </button>
                    <a href="/Category/CategoryList" class="nav-link" style="background: var(--bg-canvas); color: var(--text-muted); padding: 12px 25px; border-radius: 10px; font-weight: 600;">
                        Vazgeç
                    </a>
                </div>
            </div>
        </form>
    </div>

    <div class="side-panel">
        <div class="info-box">
            <div class="info-title" style="color: #f59e0b;">
                <i class="fa-solid fa-lightbulb"></i> Faydalı İpuçları
            </div>
            <div class="tip-item">
                <i class="fa-solid fa-circle-dot" style="font-size: 0.5rem; margin-top: 5px; color: var(--primary);"></i>
                <span>Kategori isimlerini kısa ve net tutun (Örn: Kültür, Kayak).</span>
            </div>
            <div class="tip-item">
                <i class="fa-solid fa-circle-dot" style="font-size: 0.5rem; margin-top: 5px; color: var(--primary);"></i>
                <span>Henüz turları hazır olmayan kategorileri "Pasif" bırakabilirsiniz.</span>
            </div>
        </div>

        <div class="info-box">
            <div class="info-title">
                <i class="fa-solid fa-circle-info"></i> Bilgilendirme
            </div>
            <p style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.5;">
                Oluşturduğunuz kategoriler tur ekleme ekranında listelenecektir. Kategorileri silmek yerine pasife alarak verilerinizi koruyabilirsiniz.
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}