@model Case3Vitour.Dtos.TourPlanDtos.CreateTourPlanDto
@{
    var selectedTourId = Context.Request.Query["tourId"].ToString(); // URL'den tur ID'sini yakala (opsiyonel)
    ViewData["Title"] = "Yeni Tur Planı";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ActiveMenu"] = "turplanlar";
    ViewData["Breadcrumb"] = "Tur Planları / Yeni Ekle";
}

<style>
    .create-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 24px;
        align-items: start;
    }

    .v-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    .v-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .v-card-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .v-card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--t1);
    }

    .v-card-sub {
        font-size: 11.5px;
        color: var(--t3);
        margin-top: 2px;
    }

    .form-body {
        padding: 22px 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--t2);
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label .req {
            color: #ef4444;
            font-size: 15px;
            line-height: 1;
        }

    .form-control {
        width: 100%;
        height: 42px;
        padding: 0 14px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--bg-canvas);
        color: var(--t1);
        font-family: inherit;
        font-size: 14px;
        transition: 0.2s;
        outline: none;
    }

        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
            background: #fff;
        }

    textarea.form-control {
        height: auto;
        padding: 12px 14px;
        resize: vertical;
        min-height: 140px;
    }

    .form-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #f8fafc;
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-primary:hover {
            background: #0369a1;
        }

    /* ── Canlı Önizleme CSS ── */
    .plan-preview-card {
        margin: 16px;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid var(--border);
        background: #fff;
    }

    .ppc-accent {
        height: 4px;
        transition: background .3s;
        background: #cbd5e1;
    }

    .ppc-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
    }

    .ppc-day-badge {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background .3s;
        background: #cbd5e1;
    }

    .ppc-day-num {
        font-size: 18px;
        font-weight: 900;
        line-height: 1;
        color: #fff;
    }

    .ppc-day-label {
        font-size: 9px;
        font-weight: 700;
        color: rgba(255,255,255,.75);
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    .ppc-title-wrap {
        flex: 1;
        min-width: 0;
    }

    .ppc-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--t1);
        min-height: 18px;
    }

    .ppc-body {
        padding: 14px 16px;
    }

    .ppc-desc {
        font-size: 13px;
        color: var(--t2);
        line-height: 1.65;
        white-space: pre-wrap;
        min-height: 18px;
    }
</style>

<div style="margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 800; color: var(--t1);">Yeni Tur Planı Ekle</h1>
    <p style="font-size: 13px; color: var(--t3);">Tur programı için günlük aktivite ekleyin.</p>
</div>

<div class="create-grid">
    <form method="post" asp-action="CreateTourPlan">
        @Html.AntiForgeryToken()
        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(2,132,199,.1);color:var(--accent);">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <div>
                    <div class="v-card-title">Plan Detayları</div>
                    <div class="v-card-sub">Gün, başlık ve açıklama bilgileri</div>
                </div>
            </div>

            <div class="form-body">
                <div asp-validation-summary="All" style="color:red; font-size:13px; margin-bottom:10px;"></div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-map-location-dot" style="color:var(--accent); font-size:12px;"></i>
                        Bağlı Olduğu Tur <span class="req">*</span>
                    </label>
                    <select asp-for="TourId" class="form-control" asp-items="ViewBag.Tours">
                        <option value="">— Tur Seçiniz —</option>
                    </select>
                </div>

                <div style="display:grid; grid-template-columns: 1fr 2fr; gap:16px;">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fa-solid fa-hashtag" style="color:var(--accent); font-size:12px;"></i>
                            Gün Numarası <span class="req">*</span>
                        </label>
                        <input asp-for="DayNumber" type="number" class="form-control" id="dayInput" min="1" value="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fa-solid fa-heading" style="color:var(--accent); font-size:12px;"></i>
                            Başlık <span class="req">*</span>
                        </label>
                        <input asp-for="Title" class="form-control" id="titleInput" placeholder="Örn: Şehir Turu" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-align-left" style="color:var(--accent); font-size:12px;"></i>
                        Açıklama <span class="req">*</span>
                    </label>
                    <textarea asp-for="Description" class="form-control" id="descInput" rows="6" placeholder="Bu gün yapılacak aktiviteler..."></textarea>
                </div>
            </div>

            <div class="form-footer">
                <a href="/TourPlan/AllTourPlan" style="color:var(--t3); font-size:13px; text-decoration:none; font-weight:600;">İptal</a>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-plus"></i> Planı Kaydet
                </button>
            </div>
        </div>
    </form>

    <div style="display:flex; flex-direction:column; gap:20px;">
        <div class="v-card">
            <div class="v-card-header">
                <div class="v-card-icon" style="background:rgba(168,85,247,.1);color:#a855f7;">
                    <i class="fa-solid fa-eye"></i>
                </div>
                <div>
                    <div class="v-card-title">Canlı Önizleme</div>
                    <div class="v-card-sub">Görünüm anlık yansır</div>
                </div>
            </div>

            <div class="plan-preview-card">
                <div class="ppc-accent" id="prevAccent"></div>
                <div class="ppc-header">
                    <div class="ppc-day-badge" id="prevDayBadge">
                        <div class="ppc-day-num" id="prevDayNum">1</div>
                        <div class="ppc-day-label">GÜN</div>
                    </div>
                    <div class="ppc-title-wrap">
                        <div class="ppc-title" id="prevTitle">
                            <span style="color:var(--t3);font-weight:400;font-size:12px;">Başlık girilmedi…</span>
                        </div>
                    </div>
                </div>
                <div class="ppc-body">
                    <div class="ppc-desc" id="prevDesc">
                        <span style="color:var(--t3);font-style:italic;font-size:12px;">Açıklama girilmedi…</span>
                    </div>
                </div>
            </div>
        </div>

        <div style="background: #f1f5f9; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;">
            <h4 style="font-weight: 800; margin-top: 0; font-size:14px; color:var(--t1);"><i class="fa-solid fa-circle-info" style="color:#0284c7;"></i> Bilgilendirme</h4>
            <p style="font-size: 12.5px; color: var(--t2); margin-bottom:0; line-height:1.5;">Tur planları, müşterilerin tur günlerinde ne yapacaklarını bilmeleri için kritiktir. Açıklamaları detaylı ve net yazmaya özen gösterin.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var dayColors = ['#0284c7','#16a34a','#a855f7','#f59e0b','#ef4444','#0891b2','#7c3aed','#059669','#dc2626','#d97706'];

        function updatePreview() {
            var day = parseInt(document.getElementById('dayInput').value) || 1;
            var title = document.getElementById('titleInput').value.trim();
            var desc = document.getElementById('descInput').value;
            var color = dayColors[(day - 1) % dayColors.length];

            document.getElementById('prevAccent').style.background = color;
            document.getElementById('prevDayBadge').style.background = color;
            document.getElementById('prevDayNum').textContent = day;

            var pt = document.getElementById('prevTitle');
            if(title) pt.innerHTML = title;
            else pt.innerHTML = '<span style="color:var(--t3);font-weight:400;font-size:12px;">Başlık girilmedi…</span>';

            var pd = document.getElementById('prevDesc');
            if(desc) { pd.textContent = desc; pd.style.fontStyle = 'normal'; pd.style.color = 'var(--t2)'; }
            else { pd.innerHTML = '<span style="color:var(--t3);font-style:italic;font-size:12px;">Açıklama girilmedi…</span>'; }
        }

        ['dayInput', 'titleInput', 'descInput'].forEach(function(id) {
            document.getElementById(id).addEventListener('input', updatePreview);
        });

        // URL'den TourId geldiyse otomatik seç
        var urlParams = new URLSearchParams(window.location.search);
        var tId = urlParams.get('tourId');
        if(tId) { document.getElementById('TourId').value = tId; }

        updatePreview();
    </script>
}