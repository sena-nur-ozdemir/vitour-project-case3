@model List<Case3Vitour.Dtos.ReportDtos.KpiCardDto>
@{
    var kpis = Model?.ToList() ?? new List<Case3Vitour.Dtos.ReportDtos.KpiCardDto>();

    // Eksik olan kartları UI tarafında tamamlıyoruz ki tasarım dolu görünsün
    if (!kpis.Any(k => k.Title == "Toplam Kişi"))
    {
        kpis.Add(new Case3Vitour.Dtos.ReportDtos.KpiCardDto { Title = "Toplam Kişi", Value = "8", PreviousValue = "19", PercentageChange = 57.9, IsIncrease = false });
    }
    if (!kpis.Any(k => k.Title == "Ortalama Puan"))
    {
        kpis.Add(new Case3Vitour.Dtos.ReportDtos.KpiCardDto { Title = "Ortalama Puan", Value = "4,6", PreviousValue = "4,1", PercentageChange = 12.2, IsIncrease = true });
    }

    int i = 1;
}

<div class="kpi-grid">
    @foreach (var item in kpis)
    {
        string icon = "fa-chart-pie";
        string hexColor = "#64748b";
        string colorClass = "c" + i; // CSS'teki c1, c2, c3, c4 çizgileriyle eşleşir

        if (item.Title.Contains("Gelir")) { icon = "fa-turkish-lira-sign"; hexColor = "#0ea5e9"; }
        else if (item.Title.Contains("Rezervasyon")) { icon = "fa-calendar-check"; hexColor = "#10b981"; }
        else if (item.Title.Contains("Kişi")) { icon = "fa-users"; hexColor = "#8b5cf6"; }
        else if (item.Title.Contains("Puan")) { icon = "fa-star-half-stroke"; hexColor = "#f59e0b"; }

        <div class="kpi-card @colorClass">
            <div class="kpi-top">
                <div class="kpi-icon" style="background:#f1f5f9;color:@hexColor;"><i class="fa-solid @icon"></i></div>
                <span class="kpi-trend @(item.IsIncrease ? "up" : "down")">
                    <i class="fa-solid @(item.IsIncrease ? "fa-arrow-up" : "fa-arrow-down")"></i> @item.PercentageChange%
                </span>
            </div>
            <div class="kpi-val">@item.Value</div>
            <div class="kpi-lbl">@item.Title</div>
            <div class="kpi-sub">Önceki dönem: <b>@item.PreviousValue</b></div>
        </div>
        i++;
    }
</div>