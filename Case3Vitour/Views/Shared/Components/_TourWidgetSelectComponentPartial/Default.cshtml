@using Case3Vitour.Dtos.CategoryDtos
@model List<Case3Vitour.Dtos.CategoryDtos.ResultCategoryDto>

<div class="mt--82 z-index3 relative">
    <div class="tf-container">
        <div class="row">
            <div class="col-lg-12">
                <div class="search-form-widget-slider relative">
                    <form action="/DefaultTour/TourList" method="get" id="search-form-slider">

                        <!-- GİZLİ INPUTLAR (Arama verilerini URL'ye taşır) -->
                        <input type="hidden" name="categoryId" id="hidden_categoryId" value="" />
                        <input type="hidden" name="badge" id="hidden_badge" value="" />
                        <input type="hidden" name="duration" id="hidden_duration" value="" />

                        <div class="flex wd-search">

                            <!-- 1. KATEGORİ -->
                            <div class="form-group flex">
                                <i class="icon-18"></i>
                                <div class="search-bar-group">
                                    <label>Kategori</label>
                                    <div class="nice-select" id="custom-cat-select" tabindex="0">
                                        <span class="current">Kategori Seçin</span>
                                        <ul class="list">
                                            <li data-value="" class="option selected">Tüm Kategoriler</li>
                                            @if (Model != null)
                                            {
                                                foreach (var item in Model)
                                                {
                                                    <li data-value="@item.CategoryId" class="option">@item.CategoryName</li>
                                                }
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- 2. TUR TİPİ (Senin Rozetler) -->
                            <div class="form-group flex">
                                <i class="icon-hiking-1-1 "></i>
                                <div class="search-bar-group">
                                    <label>Tur Tipi</label>
                                    <div class="nice-select" id="custom-type-select" tabindex="0">
                                        <span class="current">Tüm Tipler</span>
                                        <ul class="list">
                                            <li data-value="" class="option selected">Tüm Tipler</li>
                                            <li data-value="Popüler" class="option">Popüler</li>
                                            <li data-value="Yeni" class="option">Yeni</li>
                                            <li data-value="Fırsat" class="option">Fırsat</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- 3. SÜRE -->
                            <div class="form-group flex">
                                <i class=" icon-time-left "></i>
                                <div class="search-bar-group">
                                    <label>Süre</label>
                                    <div class="nice-select" id="custom-duration-select" tabindex="0">
                                        <span class="current">Tüm Süreler</span>
                                        <ul class="list">
                                            <li data-value="" class="option selected">Tüm Süreler</li>
                                            <li data-value="1-3" class="option">1-3 Gün</li>
                                            <li data-value="4-7" class="option">4-7 Gün</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- 4. KİŞİ SAYISI -->
                            <div class="form-group flex">
                                <i class="icon-user"></i>
                                <div class="search-bar-group">
                                    <label>Kişi Sayısı</label>
                                    <input type="text" name="guestCount" value="1">
                                </div>
                            </div>

                            <div class="form-group flex-two">
                                <div class="icon-icon-filter">
                                    <i class="icon-14"></i>
                                </div>
                                <button type="submit" class="btn-search" style="border:none; outline:none;">
                                    <i class="icon-Vector5"></i> Ara
                                </button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Kullanıcı menülerden seçim yaptığında değerleri gizli inputlara aktarır
    document.addEventListener("DOMContentLoaded", function () {
        var form = document.getElementById("search-form-slider");
        if(form) {
            form.addEventListener("submit", function () {

                // Kategoriyi yakala
                var catSelect = document.getElementById("custom-cat-select");
                if (catSelect) {
                    var selectedCat = catSelect.querySelector(".option.selected");
                    if(selectedCat) document.getElementById("hidden_categoryId").value = selectedCat.getAttribute("data-value") || "";
                }

                // Tur tipini (Rozet) yakala
                var typeSelect = document.getElementById("custom-type-select");
                if (typeSelect) {
                    var selectedType = typeSelect.querySelector(".option.selected");
                    if(selectedType) document.getElementById("hidden_badge").value = selectedType.getAttribute("data-value") || "";
                }

                // Süreyi yakala
                var durationSelect = document.getElementById("custom-duration-select");
                if (durationSelect) {
                    var selectedDuration = durationSelect.querySelector(".option.selected");
                    if(selectedDuration) document.getElementById("hidden_duration").value = selectedDuration.getAttribute("data-value") || "";
                }
            });
        }
    });
</script>