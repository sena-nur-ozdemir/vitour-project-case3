<footer class="footer footer-style1">
    <div class="tf-container">
        <div class="footer-main">
            <div class="footer-logo">
                <div class="logo-footer">
                    @* Logo yolunu kendi vitour klasörüne göre güncelledik *@
                    <img src="~/vitour/assets/images/logo2.png" alt="Case3Vitour Logo">
                </div>
                <p class="des-footer">
                    Dünyanın dört bir yanına en güvenli ve konforlu turları düzenleyen
                    Türkiye'nin lider seyahat acentesi. Hayallerinizdeki tatili
                    birlikte planlayalım.
                </p>
                <ul class="footer-info">
                    <li class="flex-three">
                        <i class="icon-noun-mail-5780740-1"></i>
                        <p>info@case3vitour.com</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Group-9"></i>
                        <p>+90 212 555 01 02</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Layer-19"></i>
                        <p>Merkez Mah. Turizm Cad. No:123 İstanbul/Türkiye</p>
                    </li>
                </ul>
            </div>

            <div class="footer-service">
                <h5 class="title">Hızlı Menü</h5>
                <ul class="footer-menu">
                    <li><a href="/About/Index">Hakkımızda</a></li>
                    <li><a href="/DefaultTour/TourList">Turlarımız</a></li>
                    <li><a href="/Destination/Index">Destinasyonlar</a></li>
                    <li><a href="/Blog/Index">Blog Yazıları</a></li>
                    <li><a href="/Contact/Index">İletişim</a></li>
                </ul>
            </div>

            <div class="footer-gallery">
                <h5 class="title">Foto Galeri</h5>
                <div class="gallery-img">
                    @* Buradaki resimler statik kalabilir ama yollarını / ile başlattık *@
                    @for (int i = 1; i <= 6; i++)
                    {
                        <a href="~/vitour/assets/images/gallery/gl@(i).jpg" data-fancybox="gallery">
                            <img src="~/vitour/assets/images/gallery/gl@(i).jpg" alt="Gallery @i">
                        </a>
                    }
                </div>
            </div>

            <div class="footer-newsletter">
                <h5 class="title">Bülten Aboneliği</h5>
                <form action="#" id="footer-form">
                    <div class="input-wrap flex-three">
                        <input type="email" placeholder="E-posta adresiniz">
                        <button type="submit"><i class="icon-paper-plane"></i></button>
                    </div>
                    <div class="check-form flex-three">
                        <i class="icon-Vector-121"></i>
                        <p>Kullanım şartlarını kabul ediyorum.</p>
                    </div>
                </form>
                @* Sosyal Medya İkonları *@
                <ul class="social-ft flex-three">
                    <li><a href="#"><i class="icon-icon-2"></i></a></li>
                    <li><a href="#"><i class="icon-x"></i></a></li>
                    <li><a href="#"><i class="icon-8"></i></a></li>
                    <li><a href="#"><i class="icon-2"></i></a></li>
                </ul>
            </div>
        </div>

        <div class="row footer-bottom">
            <div class="col-md-6">
                <p class="copy-right">Copyright © @DateTime.Now.Year Case3Vitour. Tüm Hakları Saklıdır.</p>
            </div>
            <div class="col-md-6">
                <ul class="social flex-six">
                    <li><a href="#"><i class="icon-icon-2"></i></a></li>
                    <li><a href="#"><i class="icon-x"></i></a></li>
                    <li><a href="#"><i class="icon-icon_03"></i></a></li>
                    <li><a href="#"><i class="icon-2"></i></a></li>
                </ul>
            </div>
        </div>
    </div>
</footer>