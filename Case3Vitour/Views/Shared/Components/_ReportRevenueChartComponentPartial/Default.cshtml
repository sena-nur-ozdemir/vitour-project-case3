@model List<Case3Vitour.Dtos.ReportDtos.MonthlyRevenueDto>

<div class="v-card">
    <div class="v-card-header">
        <div style="display:flex; align-items:center; gap:10px;">
            <div class="v-card-icon" style="background:rgba(14,165,233,.1);color:#0ea5e9;">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div>
                <div class="v-card-title">Aylık Gelir</div>
                <div class="v-card-sub">Son 8 ay · TL</div>
            </div>
        </div>
    </div>
    <div class="v-card-body" style="padding-bottom:10px;">
        <div class="chart-area" id="revenueChart" style="height: 260px; display: flex; align-items: flex-end; justify-content: center; padding: 10px 20px 20px 20px; gap: 15px;"></div>
    </div>

    <div style="display:flex; align-items:center; gap:12px; padding:16px 24px; background:#f8fafc; border-top:1px solid #e2e8f0;">
        <span style="font-size:13px; color:#64748b; font-weight:600;">Dışa aktar:</span>
        <button onclick="downloadCSV()" style="background:#fff; border:1px solid #e2e8f0; padding:6px 12px; border-radius:6px; cursor:pointer; font-weight:600; color:var(--t2);">
            <i class="fa-solid fa-file-csv" style="color:#475569; margin-right:4px;"></i> CSV
        </button>
        <button onclick="downloadCSV()" style="background:#fff; border:1px solid #e2e8f0; padding:6px 12px; border-radius:6px; cursor:pointer; font-weight:600; color:var(--t2);">
            <i class="fa-regular fa-file-excel" style="color:#16a34a; margin-right:4px;"></i> Excel
        </button>
    </div>
</div>

<script>
    var chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => new { month = x.Month, val = x.Revenue })));

    (function() {
        var max = Math.max(...chartData.map(d => d.val));
        var chart = document.getElementById('revenueChart');
        if (!chart) return;
        chart.innerHTML = "";

        chartData.forEach(function(d) {
            var h = max === 0 ? 0 : Math.round((d.val / max) * 100);
            h = h < 5 ? 5 : h;
            var wrap = document.createElement('div');
            // Barların kalınlığı max-width ile artırıldı
            wrap.style = "flex: 1; max-width: 90px; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; position: relative; margin: 0 4px;";

            wrap.innerHTML =
                '<div style="width: 100%; border-radius: 6px 6px 0 0; background: #0ea5e9; cursor: pointer; transition: opacity .2s; min-height: 5px; height:' + h + '%;" onmouseover="this.style.opacity=\'.8\'; this.children[0].style.display=\'block\'" onmouseout="this.style.opacity=\'1\'; this.children[0].style.display=\'none\'">' +
                    '<div style="display:none; position:absolute; bottom:calc(100% + 8px); left:50%; transform:translateX(-50%); background:#1e293b; color:#fff; font-size:12px; font-weight:600; padding:6px 10px; border-radius:6px; white-space:nowrap; z-index:10;">₺' + d.val.toLocaleString('tr-TR') + '</div>' +
                '</div>' +
                '<div style="font-size:12px; color:#94a3b8; font-weight:600; position:absolute; bottom:-24px;">' + d.month + '</div>';

            chart.appendChild(wrap);
        });
    })();

    // Çalışan İndirme Fonksiyonu
    function downloadCSV() {
        let csvContent = "data:text/csv;charset=utf-8,Ay,Gelir\n";
        chartData.forEach(function(rowArray) {
            csvContent += rowArray.month + "," + rowArray.val + "\n";
        });
        var encodedUri = encodeURI(csvContent);
        var link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "Aylik_Gelir_Raporu.csv");
        document.body.appendChild(link);
        link.click();
    }
</script>