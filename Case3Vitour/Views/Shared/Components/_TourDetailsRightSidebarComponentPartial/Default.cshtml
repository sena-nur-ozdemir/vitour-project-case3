<div class="col-lg-4">
    <div class="side-bar-right">
        @* 1. Rezervasyon Kartı *@
        <div class="sidebar-widget">
            <h6 class="block-heading" style="margin-bottom: 20px;">Bu Turu Rezerve Et</h6>

            @* Kullanıcı tarafındaki rezervasyon sayfasına gidiyor *@
            <a href="/DefaultReservation/CreateReservation/@ViewBag.TourId"
               style="display:block;
                      text-align:center;
                      padding: 14px 20px;
                      background-color: #28a745;
                      color: #fff;
                      border-radius: 8px;
                      font-weight: 600;
                      font-size: 16px;
                      text-decoration: none;
                      transition: background 0.3s ease;">
                🗓️ Rezervasyon Yap
            </a>

            <p style="font-size: 13px; color: #666; text-align: center; margin-top: 12px;">
                * Rezervasyon sonrası onay için aranacaksınız.
            </p>
        </div>

        @* 2. Güvenlik ve Avantajlar Kartı *@
        <div class="sidebar-widget">
            <h6 class="block-heading">Güvenle Rezervasyon Yapın</h6>
            <ul class="category-confidence">
                <li class="flex-three">
                    <i class="icon-customer-service-1"></i>
                    <span>7/24 Müşteri Desteği</span>
                </li>
                <li class="flex-three">
                    <i class="icon-Vector-6"></i>
                    <span>Özenle Seçilmiş Turlar</span>
                </li>
                <li class="flex-three">
                    <i class="icon-insurance-1"></i>
                    <span>Ücretsiz Seyahat Sigortası</span>
                </li>
                <li class="flex-three">
                    <i class="icon-price-tag-1-1"></i>
                    <span>En İyi Fiyat Garantisi</span>
                </li>
            </ul>
        </div>

        @* 3. Son 3 Tur Bileşeni *@
        @await Component.InvokeAsync("_TourDetailsSidebarLast3TourComponentPartial")
    </div>
</div>